# Supabase Configuration (Auto-configured by Lovable)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Backend API — NestJS base URL (must NOT be the same URL that serves the React build).
# Wrong: http://yoursite.com:3001 (that is usually the SPA; /user etc. return index.html).
# Right:  http://yoursite.com:9000  or https://api.yoursite.com  (where Nest listens).
VITE_API_BASE_URL=https://api.exbuysell.com
VITE_API_BEARER_TOKEN=your_bearer_token_here
# Socket.IO — same host:port as the API unless you run the gateway elsewhere
VITE_WS_URL=https://api.exbuysell.com
